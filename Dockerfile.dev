# Use a smaller official Node.js base image
FROM node:22-bookworm-slim

# Set the working directory to /delta
WORKDIR /delta

# Copy dependency manifests (use yarn.lock for deterministic versions)
COPY package.json yarn.lock ./

# Install dependencies using the lockfile (ensures esbuild matches vite's expectation)
RUN HUSKY=0 yarn install --frozen-lockfile

# Copy the rest of the application code to the working directory
COPY . .

# Expose the port that the application will use
EXPOSE 3000

# Set the environment variables
ENV NODE_ENV=development
ENV PORT=3000

# Run migrations and start development server
CMD ["sh", "-c", "yarn dbsync && yarn react-router dev --host 0.0.0.0 --port 3000"]
