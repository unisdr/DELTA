# Environment file for integration tests (yarn test:run3) and E2E tests (yarn test:e2e).
#
# Copy this file to .env.test and update values to match your environment.
#
# For Docker deployments, the defaults below match docker-compose.yml.
# For manual installations, update DATABASE_URL to point at your local PostgreSQL.

# --- Database ---
# test:run3 connects directly to this database.
# test:e2e creates a temporary database named <dbname>_e2e_test, runs tests,
# then drops it — requires the user to have CREATE DATABASE permission.
#
# Docker default (matches docker-compose.yml):
DATABASE_URL="postgres://postgres:2024@localhost:5432/dts_development"

# --- E2E / Playwright ---
# Must match the port the app server runs on (yarn dev uses --port 3000).
PORT="3000"
PUBLIC_URL="http://localhost:3000"
SESSION_SECRET="not-random-test-secret"
AUTHENTICATION_SUPPORTED="form"
