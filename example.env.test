# Environment file for real-DB integration tests (yarn test:run3).
#
# Copy this file to .env.test and update DATABASE_URL to point at a
# dedicated test database. The test suite currently only requires
# DATABASE_URL; other variables (SESSION_SECRET, EMAIL_*, etc.) are not
# used by the integration-realdb tests at this time.
#
# TODO: review whether additional env vars are needed as test coverage
# expands (e.g. for routes that depend on session or email config).

DATABASE_URL="postgresql://user1@localhost/db1?host=/var/run/postgresql/&schema=public"
